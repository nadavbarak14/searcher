{
  "name": "searcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "build": "npm run typecheck && vite build",
    "start": "vite build && tsc -p tsconfig.build.json && node dist/src/main.js",
    "serve": "node dist/src/main.js",
    "dev:web": "vite",
    "dev:server": "tsc -p tsconfig.build.json && node dist/src/main.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@xyflow/react": "^12.11.0",
    "fastify": "^5.8.5",
    "gray-matter": "^4.0.3",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
